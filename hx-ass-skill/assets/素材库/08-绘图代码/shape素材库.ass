;; ===== 特殊字体 =====

;; 雪花数字 (需安装 Faux Snow BRK 字体)
;; 用法: {\fnFaux Snow BRK}!math.random(0,9)!
;; 效果: 数字 0-9 显示为不同形状的雪花

;; BO NX Bold (数字矩阵)
;; 用法: {\fnBO NX Bold}!math.random(0,9)!
;; 效果: 数字显示为点阵/像素风格

;; ===== 使用示例 =====

[Events]
Format: Layer, Start, End, Style, Name, MarginL, MarginR, MarginV, Effect, Text

;; 初始化所有 shape
Comment: 0,0:00:00.00,0:00:00.00,OPJP,,0,0,0,code once,shape = { rect = "m 0 0 l 0 100 l 100 100 l 100 0 l 0 0", circle = "m 100 0 b 100 -55 55 -100 0 -100 b -55 -100 -100 -55 -100 0 b -100 55 -55 100 0 100 b 55 100 100 55 100 0", tri = "m 0 0 l -10 15 l 10 15", feather = "m 26 37 l 38 27 l 45 19 l 52 11 l 57 7 b 66 0 72 9 64 29 l 59 26 l 62 31 b 58 36 52 43 46 47 l 41 44 l 44 48 b 41 52 37 56 33 58 l 28 52 l 30 58 l 27 61 l 24 58 l 24 61 l 21 58 l 17 61 l 17 59 b 11 62 6 64 0 64 l 0 60 b 5 60 12 57 16 54 l 14 51 l 18 51 l 17 47 l 20 50 l 20 42 l 24 38 l 25 45", rain = "m 0 0 l 2 0 l 2 50 l 0 50 l 0 0", stick = "m 0 0 l 3 -36 l 6 0 l 3 12" }

;; 在 template 中引用: !shape.rect! / !shape.circle! / !shape.feather! 等
