;; ========================================
;; 齿轮旋转 (命运石之门 0 OP - OP JP 3)
;; ========================================
;; 适用: 机械/命运/时间主题，或需要装饰感的静态段落
;; 特点: 行首尾各一个齿轮图案，全程旋转；文字静态+微动
;; 来源: 命运石之门 0 OP1.ass - OP JP 3 + OP JP (Seekladoom)
;;
;; 两种用法:
;;   A. 装饰齿轮 (行首/尾旋转装饰, 所有OP JP样式共用)
;;   B. 微动齿轮 (字符周围小齿轮, OP JP 3专用)
;;
;; ========================================

[Events]
Format: Layer, Start, End, Style, Name, MarginL, MarginR, MarginV, Effect, Text

;; --- 齿轮 shape 定义 ---
Comment: 0,0:00:00.00,0:00:00.00,OPJP,,0,0,0,code once,gear = { "m 227 112 l 226 130 l 206 131 l 202 147 l 218 158 l 210 174 l 191 167 l 180 180 l 191 197 l 177 208 l 163 194 l 147 201 l 150 221 l 133 225 l 126 207 l 109 207 l 103 226 l 85 223 l 87 203 l 71 197 l 58 212 l 43 202 l 52 185 l 41 172 l 22 181 l 13 166 l 29 153 l 23 138 l 3 138 l 0 120 l 20 115 l 21 98 l 2 91 l 7 74 l 27 77 l 35 62 l 21 47 l 32 34 l 49 45 l 63 34 l 56 15 l 72 8 l 83 24 l 99 20 l 101 0 l 118 0 l 121 20 l 138 22 l 148 5 l 164 11 l 159 31 l 173 40 l 189 28 l 201 41 l 189 56 l 198 71 l 217 66 l 223 83 l 205 92 l 208 108 l 227 112 m 114 48 l 114 48 b 78 48 49 77 49 113 b 49 149 78 178 114 178 b 150 178 179 149 179 113 b 179 77 150 48 114 48 "}

;; --- fxgroup: 仅首音节触发 ---
Comment: 0,0:00:00.00,0:00:00.00,Default,,0,0,0,code syl all,fxgroup.firstsyl = syl.i == 1

;; --- A. 装饰齿轮 (行左侧, 逆时针360°) ---
Comment: 0,0:00:00.00,0:00:00.00,OPJP,,0,0,0,template notext fxgroup firstsyl,{\an5\pos(!$lleft-33!,$middle)\3cFFFFFF\blur2\bord1.5\t(0,$ldur,\frz-360)\fad(0,350)\p3}!gear[1]!

;; --- A. 装饰齿轮 (行右侧, 顺时针360°) ---
Comment: 0,0:00:00.00,0:00:00.00,OPJP,,0,0,0,template notext fxgroup firstsyl,{\an5\pos(!$lright+30!,$middle)\3cFFFFFF\blur2\bord1.5\t(0,$ldur,\frz360)\fad(0,350)\p3}!gear[1]!

;; --- B. 微动齿轮 (字符周围小齿轮, 用于静态段落) ---
;; X/Y 偏移量定义
Comment: 0,0:00:00.00,0:00:00.00,OPJP,,0,0,0,code once,X = {-10,0,10}; Y = {-10,0,10}

;; 文字: 静态显示 + fad(300,300)
Comment: 1,0:00:00.00,0:00:00.00,OPJP,,0,0,0,template syl noblank char,!retime("line",0,0)!{\an5\pos($center,$middle)\blur1\fad(300,300)}

;; 小齿轮: 随机偏移位置，从180°旋到-180°
Comment: 0,0:00:00.00,0:00:00.00,OPJP,,0,0,0,template noblank notext,!retime("syl2end",-500,0)!{\an5\pos(!$center+X[math.random(1,3)]!,!$middle+Y[math.random(1,3)]!)\blur1\frz180\t(0,$ldur,0.8,\frz-180)\fad(300,300)\fscx15\fscy15\p1}!gear[1]!
