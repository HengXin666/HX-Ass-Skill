;; ========================================
;; 碎片组装 (命运石之门 0 OP - OP JP 2)
;; ========================================
;; 适用: 科技感/悬疑/拼凑真相的叙事氛围
;; 特点: 每字分4象限clip，各自从远处3D旋转飞入拼合
;; 来源: 命运石之门 0 OP1.ass - OP JP 2 (Seekladoom)
;;
;; 原理:
;;   1. 将每个字符用 \clip 切成4块 (左上/左下/右上/右下)
;;   2. 4块分别从不同方向飞入 (60-80px外)
;;   3. 同时随机3D旋转 frx/fry/frz → 0
;;   4. 到达位置后旋转归零，碎片拼合成完整文字
;;
;; ========================================

[Events]
Format: Layer, Start, End, Style, Name, MarginL, MarginR, MarginV, Effect, Text

;; --- 左上碎片: 从左上方飞入 ---
Comment: 0,0:00:00.00,0:00:00.00,OPJP,,0,0,0,template char noblank,!retime("syl",0,0)!{\an5\blur1\clip(!$center-30!,!$middle-30!,$center,$middle)\frx!math.random(-360,360)!\fry!math.random(-360,360)!\frz!math.random(-360,360)!\t(0,$dur,\frx0\fry0\frz0)\move(!$center-math.random(60,80)!,!$middle-math.random(60,80)!,$center,$middle)}

;; --- 左下碎片: 从左下方飞入 ---
Comment: 0,0:00:00.00,0:00:00.00,OPJP,,0,0,0,template char noblank,!retime("syl",0,0)!{\an5\blur1\clip(!$center-30!,$middle,$center,!$middle+30!)\frx!math.random(-360,360)!\fry!math.random(-360,360)!\frz!math.random(-360,360)!\t(0,$dur,\frx0\fry0\frz0)\move(!$center-math.random(60,80)!,!$middle+math.random(60,80)!,$center,$middle)}

;; --- 右上碎片: 从右上方飞入 ---
Comment: 0,0:00:00.00,0:00:00.00,OPJP,,0,0,0,template char noblank,!retime("syl",0,0)!{\an5\blur1\clip($center,!$middle-30!,!$center+30!,$middle)\frx!math.random(-360,360)!\fry!math.random(-360,360)!\frz!math.random(-360,360)!\t(0,$dur,\frx0\fry0\frz0)\move(!$center+math.random(60,80)!,!$middle-math.random(60,80)!,$center,$middle)}

;; --- 右下碎片: 从右下方飞入 ---
Comment: 0,0:00:00.00,0:00:00.00,OPJP,,0,0,0,template char noblank,!retime("syl",0,0)!{\an5\blur1\clip($center,$middle,!$center+30!,!$middle+30!)\frx!math.random(-360,360)!\fry!math.random(-360,360)!\frz!math.random(-360,360)!\t(0,$dur,\frx0\fry0\frz0)\move(!$center+math.random(60,80)!,!$middle+math.random(60,80)!,$center,$middle)}

;; --- 拼合后保持到行尾 ---
Comment: 0,0:00:00.00,0:00:00.00,OPJP,,0,0,0,template char noblank,!retime("syl2end",0,300)!{\an5\pos($center,$middle)\blur1\fad(0,300)}
